#!/usr/bin/env bash
# tmux-claude-status — Claude Code session info for tmux status bar
#
# Displays model name, effort level, context usage %, API quota, and
# estimated token cost for the Claude Code session running in the given
# tmux pane.  Outputs nothing when the active pane is not running Claude.
#
# Usage: tmux-claude-status <pane_pid> [model|quota]
#   model  — line 0: model (effort) │ Ctx: bar pct%
#   quota  — line 1: quota bars │ $session / $daily
# Called by tmux via: #(~/.local/bin/tmux-claude-status "#{pane_pid}" model)

PANE_PID="$1"
LINE_MODE="${2:-model}"
[ -z "$PANE_PID" ] && exit 0
[ -z "$HOME" ] && HOME=$(eval echo ~)
CLAUDE_DIR="${HOME}/.claude"

# ── Find the Claude session for this pane ──────────────────────
# Walk parent chain from each Claude process PID to see if it descends
# from the given tmux pane PID. Extract cwd from the matching session file.
SESSION_CWD=""
for pidfile in "${CLAUDE_DIR}/sessions/"*.json; do
    [ -f "$pidfile" ] || continue
    pid=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['pid'])" "$pidfile" 2>/dev/null)
    [ -z "$pid" ] && continue
    check_pid="$pid"
    while [ -n "$check_pid" ] && [ "$check_pid" != "1" ] && [ "$check_pid" != "0" ]; do
        if [ "$check_pid" = "$PANE_PID" ]; then
            SESSION_CWD=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['cwd'])" "$pidfile" 2>/dev/null)
            break 2
        fi
        check_pid=$(ps -o ppid= -p "$check_pid" 2>/dev/null | tr -d ' ')
    done
done
[ -z "$SESSION_CWD" ] && exit 0

# ── Find the session transcript via cwd → project directory ────
# Claude Code names project dirs by replacing / with - in the cwd path.
PROJECT_DIR_NAME=$(echo "$SESSION_CWD" | tr '/' '-')
PROJECT_DIR="${CLAUDE_DIR}/projects/${PROJECT_DIR_NAME}"
[ -d "$PROJECT_DIR" ] || exit 0

# Most recently modified .jsonl is the active transcript
TRANSCRIPT=$(ls -t "$PROJECT_DIR"/*.jsonl 2>/dev/null | head -1)
[ -z "$TRANSCRIPT" ] && exit 0

# ── Parse model, context, effort, quota, and cost from transcript ─
eval "$(TRANSCRIPT="$TRANSCRIPT" python3 << PYEOF
import re, json, shlex, os, time, glob, urllib.request

transcript = os.environ["TRANSCRIPT"]
model = ""
used_pct = 0
effort = ""
has_thinking = False

with open(transcript, "rb") as f:
    f.seek(0, 2)
    size = f.tell()
    chunk_size = min(size, 512000)
    f.seek(size - chunk_size)
    data = f.read().decode("utf-8", errors="replace")

found_model = False
found_effort = False
conversation_id = ""

for line in reversed(data.strip().split("\n")):
    if found_model and found_effort and conversation_id:
        break
    try:
        d = json.loads(line)
    except:
        continue

    # Grab conversation session ID from any message that has it
    if not conversation_id and "sessionId" in d:
        conversation_id = d["sessionId"]

    # Parse model from the most recent assistant message + detect thinking
    if not found_model and d.get("type") == "assistant":
        msg = d.get("message", {})
        if isinstance(msg, dict) and "model" in msg:
            model = msg["model"]
            found_model = True
            content = msg.get("content", [])
            if isinstance(content, list):
                has_thinking = any(
                    isinstance(c, dict) and c.get("type") == "thinking"
                    for c in content
                )

    # Parse effort from the most recent /effort command output
    if not found_effort and d.get("type") == "user":
        content = d.get("message", {}).get("content", "")
        if isinstance(content, str) and "<local-command-stdout>" in content:
            tags = re.findall(r"<local-command-stdout>(.*?)</local-command-stdout>", content)
            for tag in reversed(tags):
                m = re.search(r"(?:Set effort level to |Effort level: )(\w+)", tag)
                if m:
                    effort = m.group(1)
                    found_effort = True
                    break

# Fallback: read effortLevel from ~/.claude/settings.json
if not found_effort:
    try:
        _settings = json.load(open(os.path.join(os.path.expanduser("~"), ".claude", "settings.json")))
        _el = _settings.get("effortLevel", "")
        if _el:
            effort = _el
            found_effort = True
    except:
        pass

# Final fallback
if not effort:
    effort = "auto"

# Read context % from bridge file (written by statusline hook, authoritative)
# Check tmux-status path first, fall back to legacy coderig path.
if conversation_id:
    _home = os.path.expanduser("~")
    for _cache_dir in [os.path.join(_home, ".cache", "tmux-status"),
                       os.path.join(_home, ".cache", "coderig")]:
        bridge = os.path.join(_cache_dir, f"claude-ctx-{conversation_id}.json")
        try:
            bd = json.load(open(bridge))
            if time.time() - bd.get("timestamp", 0) < 1800:
                used_pct = bd.get("used_pct", used_pct)
                break
        except:
            continue

# Read settings from settings.conf
_home = os.path.expanduser("~")
_config_dir = os.environ.get("XDG_CONFIG_HOME", os.path.join(_home, ".config"))
_settings_file = os.path.join(_config_dir, "tmux-status", "settings.conf")
quota_bridge = os.path.join(_home, ".cache", "tmux-status", "claude-quota.json")
quota_source = "http://127.0.0.1:7850"
quota_api_key = ""
quota_cache_ttl = 30
try:
    with open(_settings_file) as _sf:
        for _line in _sf:
            _line = _line.strip()
            if _line.startswith("#") or "=" not in _line:
                continue
            _k, _v = _line.split("=", 1)
            _k = _k.strip()
            _v = _v.strip().strip("'\"")
            if _k == "QUOTA_DATA_PATH":
                _v = os.path.expanduser(_v)
                if _v:
                    quota_bridge = _v
            elif _k == "QUOTA_SOURCE":
                quota_source = _v
            elif _k == "QUOTA_API_KEY":
                quota_api_key = _v
            elif _k == "QUOTA_CACHE_TTL":
                try:
                    quota_cache_ttl = int(_v)
                except ValueError:
                    pass
except Exception:
    pass

# Fetch quota from server if QUOTA_SOURCE is configured
def _maybe_fetch_quota(source_url, api_key, cache_ttl, cache_path):
    """Fetch quota from server, write to disk cache. Silent on failure."""
    if not source_url:
        return
    if cache_ttl > 0:
        try:
            if time.time() - os.stat(cache_path).st_mtime < cache_ttl:
                return  # cache is fresh
        except FileNotFoundError:
            pass
    try:
        req = urllib.request.Request(source_url.rstrip('/') + '/quota')
        if api_key:
            req.add_header('X-API-Key', api_key)
        resp = urllib.request.urlopen(req, timeout=3)
        data = resp.read()
        json.loads(data)  # validate JSON
        cache_dir = os.path.dirname(cache_path)
        if cache_dir:
            os.makedirs(cache_dir, exist_ok=True)
        tmp = cache_path + '.tmp'
        with open(tmp, 'wb') as f:
            f.write(data)
        os.replace(tmp, cache_path)
    except Exception:
        pass  # silent failure, use stale cache

_maybe_fetch_quota(quota_source, quota_api_key, quota_cache_ttl, quota_bridge)
if not os.path.exists(quota_bridge):
    quota_bridge = None
quota_status = "none"
five_hour_pct = 0
five_hour_reset = ""
seven_day_pct = 0
seven_day_reset = ""
key_expires_at = ""
if quota_bridge:
    try:
        qd = json.load(open(quota_bridge))
        quota_status = qd.get("status", "none")
        key_expires_at = qd.get("expires_at", "")
        if quota_status == "ok":
            fh = qd.get("five_hour", {})
            fh_util = fh.get("utilization", 0)
            five_hour_pct = "X" if fh_util is None or fh_util == "X" else round(fh_util)
            five_hour_reset = fh.get("resets_at", "")
            sd = qd.get("seven_day", {})
            sd_util = sd.get("utilization", 0)
            seven_day_pct = "X" if sd_util is None or sd_util == "X" else round(sd_util)
            seven_day_reset = sd.get("resets_at", "")
        elif quota_status == "error":
            five_hour_pct = "X"
            seven_day_pct = "X"
            fh = qd.get("five_hour", {})
            five_hour_reset = fh.get("resets_at", "")
            sd = qd.get("seven_day", {})
            seven_day_reset = sd.get("resets_at", "")
        else:
            five_hour_pct = "X"
            seven_day_pct = "X"
    except:
        pass

def fmt_reset(iso_str):
    if not iso_str:
        return "?"
    try:
        from datetime import datetime, timezone
        reset = datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
        delta = reset - datetime.now(timezone.utc)
        secs = max(0, int(delta.total_seconds()))
        if secs >= 86400:
            return f"{secs / 86400:.1f}d"
        elif secs >= 3600:
            return f"{secs / 3600:.1f}h"
        else:
            return f"{secs // 60}m"
    except:
        return "?"

# Check if key expiry is within 24h for warning
key_expiry_warn = False
if key_expires_at:
    try:
        from datetime import datetime, timezone
        exp = datetime.fromisoformat(key_expires_at.replace("Z", "+00:00"))
        key_expiry_warn = (exp - datetime.now(timezone.utc)).total_seconds() < 86400
    except:
        pass

# ── Cost calculation ──────────────────────────────────────────
PRICING = {
    "opus":   {"input": 15.0, "output": 75.0, "cache_write": 18.75, "cache_read": 1.50},
    "sonnet": {"input": 3.0,  "output": 15.0, "cache_write": 3.75,  "cache_read": 0.30},
    "haiku":  {"input": 1.0,  "output": 5.0,  "cache_write": 1.25,  "cache_read": 0.10},
}

def _model_family(model_name):
    m = model_name.lower()
    if "opus" in m: return "opus"
    if "haiku" in m: return "haiku"
    return "sonnet"

def _calc_cost_file(path):
    """Sum token costs across all assistant messages in a JSONL file."""
    cost = 0.0
    try:
        with open(path) as f:
            for line in f:
                try:
                    d = json.loads(line)
                    if d.get("type") != "assistant":
                        continue
                    msg = d.get("message", {})
                    if not isinstance(msg, dict):
                        continue
                    usage = msg.get("usage")
                    mdl = msg.get("model", "")
                    if not usage or not mdl:
                        continue
                    prices = PRICING[_model_family(mdl)]
                    cost += (
                        usage.get("input_tokens", 0) * prices["input"]
                        + usage.get("output_tokens", 0) * prices["output"]
                        + usage.get("cache_creation_input_tokens", 0) * prices["cache_write"]
                        + usage.get("cache_read_input_tokens", 0) * prices["cache_read"]
                    ) / 1_000_000
                except Exception:
                    continue
    except Exception:
        pass
    return cost

# Session cost: current transcript + its subagents
session_cost = _calc_cost_file(transcript)
_transcript_stem = os.path.splitext(os.path.basename(transcript))[0]
_subagents_dir = os.path.join(os.path.dirname(transcript), _transcript_stem, "subagents")
if os.path.isdir(_subagents_dir):
    for _sa in glob.glob(os.path.join(_subagents_dir, "*.jsonl")):
        session_cost += _calc_cost_file(_sa)

# Daily cost: cached with 60s TTL
_daily_cache = os.path.join(_home, ".cache", "tmux-status", "claude-daily-cost.json")
daily_cost = 0.0
_daily_fresh = False
try:
    _dc = json.load(open(_daily_cache))
    if time.time() - _dc.get("timestamp", 0) < 60:
        daily_cost = _dc.get("daily_cost", 0.0)
        _daily_fresh = True
except Exception:
    pass

if not _daily_fresh:
    from datetime import datetime as _DT
    _today_start = _DT.now().replace(hour=0, minute=0, second=0, microsecond=0).timestamp()
    _projects_dir = os.path.join(_home, ".claude", "projects")
    if os.path.isdir(_projects_dir):
        for _root, _dirs, _files in os.walk(_projects_dir):
            for _fname in _files:
                if not _fname.endswith(".jsonl"):
                    continue
                _fpath = os.path.join(_root, _fname)
                try:
                    if os.stat(_fpath).st_mtime >= _today_start:
                        daily_cost += _calc_cost_file(_fpath)
                except Exception:
                    continue
    try:
        _dc_dir = os.path.dirname(_daily_cache)
        os.makedirs(_dc_dir, exist_ok=True)
        _tmp = _daily_cache + ".tmp"
        with open(_tmp, "w") as f:
            json.dump({"daily_cost": round(daily_cost, 2), "timestamp": time.time()}, f)
        os.replace(_tmp, _daily_cache)
    except Exception:
        pass

def _fmt_cost(c):
    if c >= 100:
        return f"{c:.0f}"
    elif c >= 10:
        return f"{c:.1f}"
    else:
        return f"{c:.2f}"

print("MODEL=" + shlex.quote(model))
print("USED_PCT=" + str(used_pct))
print("EFFORT=" + shlex.quote(effort))
print("HAS_THINKING=" + ("1" if has_thinking else "0"))
print("QUOTA_STATUS=" + shlex.quote(quota_status))
print("QUOTA_5H_PCT=" + shlex.quote(str(five_hour_pct)))
print("QUOTA_5H_REMAIN=" + shlex.quote(fmt_reset(five_hour_reset)))
print("QUOTA_7D_PCT=" + shlex.quote(str(seven_day_pct)))
print("QUOTA_7D_REMAIN=" + shlex.quote(fmt_reset(seven_day_reset)))
print("KEY_EXPIRY_WARN=" + ("1" if key_expiry_warn else "0"))
print("SESSION_COST=" + shlex.quote(_fmt_cost(session_cost)))
print("DAILY_COST=" + shlex.quote(_fmt_cost(daily_cost)))
PYEOF
)"
[ -z "$MODEL" ] && exit 0

# ── Shorten model name ────────────────────────────────────────
short_model="$MODEL"
case "$MODEL" in
    *opus*4*6*|*4*6*opus*)       short_model="Opus 4.6" ;;
    *opus*4*|*4*opus*)           short_model="Opus 4" ;;
    *sonnet*4*6*|*4*6*sonnet*)   short_model="Sonnet 4.6" ;;
    *sonnet*4*5*|*4*5*sonnet*)   short_model="Sonnet 4.5" ;;
    *sonnet*4*|*4*sonnet*)       short_model="Sonnet 4" ;;
    *sonnet*3*5*|*3*5*sonnet*)   short_model="Sonnet 3.5" ;;
    *haiku*4*5*|*4*5*haiku*)     short_model="Haiku 4.5" ;;
    *haiku*3*5*|*3*5*haiku*)     short_model="Haiku 3.5" ;;
esac
# Append context window size
case "$MODEL" in
    *opus*) short_model="$short_model 1M" ;;
esac

# ── Bar character + color from percentage ──────────────────────
bar_char() {
    local pct="$1"
    local chars=("_" "▂" "▃" "▄" "▅" "▆" "▇" "█")
    local colors=(34 70 106 142 178 214 208 196)
    # Non-numeric input (e.g. "X"): return error indicator
    if ! [ "$pct" -eq "$pct" ] 2>/dev/null; then
        echo "#[fg=colour196]✕"
        return
    fi
    local idx=0
    if   [ "$pct" -le 0 ]  2>/dev/null; then idx=0
    elif [ "$pct" -le 12 ] 2>/dev/null; then idx=0
    elif [ "$pct" -le 25 ] 2>/dev/null; then idx=1
    elif [ "$pct" -le 37 ] 2>/dev/null; then idx=2
    elif [ "$pct" -le 50 ] 2>/dev/null; then idx=3
    elif [ "$pct" -le 62 ] 2>/dev/null; then idx=4
    elif [ "$pct" -le 75 ] 2>/dev/null; then idx=5
    elif [ "$pct" -le 87 ] 2>/dev/null; then idx=6
    else idx=7
    fi
    echo "#[fg=colour${colors[$idx]}]${chars[$idx]}"
}

# ── Segment colors ─────────────────────────────────────────────
# Pastel palette for each segment; bar chars retain their own percentage colors.
C_MODEL="colour117"   # soft sky blue
C_CTX="colour150"     # sage green
C_5H="colour223"      # light peach/orange
C_7D="colour186"      # soft wheat
C_COST="colour183"    # light lavender

# ── Output (mode-dependent) ───────────────────────────────────
if [ "$LINE_MODE" = "model" ]; then
    # Line 0: Model (effort) │ Ctx: bar pct%
    CTX_BAR=$(bar_char "$USED_PCT")

    EFFORT_DISPLAY="$EFFORT"
    [ "${HAS_THINKING:-0}" = "1" ] && [ "$EFFORT" = "auto" ] && EFFORT_DISPLAY="auto+"

    printf " #[fg=${C_MODEL}]%s #[fg=colour8](#[fg=${C_MODEL}]%s#[fg=colour8]) #[fg=colour8]│ #[fg=${C_CTX}]Ctx: %s #[fg=${C_CTX}]%s%%" \
        "$short_model" \
        "$EFFORT_DISPLAY" \
        "$CTX_BAR" "$USED_PCT"

elif [ "$LINE_MODE" = "quota" ]; then
    # Line 1: Quota bars │ $session / $daily
    QUOTA_5H_BAR=$(bar_char "$QUOTA_5H_PCT")
    QUOTA_7D_BAR=$(bar_char "$QUOTA_7D_PCT")

    # Determine quota text color: red on error/expiry, normal otherwise
    QUOTA_COLOR="colour7"
    case "$QUOTA_STATUS" in
        session_key_expired|blocked|error|rate_limited|key_expired) QUOTA_COLOR="colour196" ;;
        *) [ "${KEY_EXPIRY_WARN:-0}" = "1" ] && QUOTA_COLOR="colour196" ;;
    esac

    # Override quota segment colors on error/expiry
    if [ "$QUOTA_COLOR" = "colour196" ]; then
        C_5H="colour196"
        C_7D="colour196"
    fi

    # Format quota pct display: "X" stays as "X", numeric gets "%"
    fmt_quota_pct() {
        if [ "$1" = "X" ]; then echo "X"; else echo "${1}%"; fi
    }
    QUOTA_5H_DISPLAY=$(fmt_quota_pct "$QUOTA_5H_PCT")
    QUOTA_7D_DISPLAY=$(fmt_quota_pct "$QUOTA_7D_PCT")

    COST_SEG="#[fg=colour8]│ #[fg=${C_COST}]\$${SESSION_COST} #[fg=colour8]/ #[fg=${C_COST}]\$${DAILY_COST}"

    if [ "$QUOTA_STATUS" = "no_key" ] || [ "$QUOTA_STATUS" = "none" ]; then
        printf " %s" "$COST_SEG"
    else
        printf " #[fg=${C_5H}]%s: %s #[fg=${C_5H}]%s #[fg=colour8]│ #[fg=${C_7D}]%s: %s #[fg=${C_7D}]%s %s" \
            "$QUOTA_5H_REMAIN" "$QUOTA_5H_BAR" "$QUOTA_5H_DISPLAY" \
            "$QUOTA_7D_REMAIN" "$QUOTA_7D_BAR" "$QUOTA_7D_DISPLAY" \
            "$COST_SEG"
    fi
fi
