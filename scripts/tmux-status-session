#!/usr/bin/env bash
# tmux-status-session — Data-driven tmux session launcher
#
# Reads a windows.json file to create a tmux session with named windows
# and auto-run commands. Re-attaches if the session already exists.
#
# Usage:
#   tmux-status-session                          # uses default config path
#   tmux-status-session /path/to/windows.json    # custom config
#
# Config format (windows.json):
#   {
#     "session_name": "main",
#     "windows": [
#       { "name": "shell", "commands": [] },
#       { "name": "claude", "commands": ["claude"] },
#       { "name": "server", "commands": ["cd ~/projects/app", "npm run dev"] }
#     ]
#   }

set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmux-status"
WINDOWS_FILE="${1:-$CONFIG_DIR/windows.json}"

if [ ! -f "$WINDOWS_FILE" ]; then
    echo "tmux-status-session: no windows.json found at: $WINDOWS_FILE"
    echo ""
    echo "Create one from the example:"
    echo "  cp ${CONFIG_DIR}/windows.example.json ${CONFIG_DIR}/windows.json"
    echo ""
    echo "Or specify a path:"
    echo "  tmux-status-session /path/to/windows.json"
    exit 1
fi

# ── Parse windows.json with python3 ───────────────────────────
# Emits shell variable assignments: SESSION, WINDOW_COUNT,
# WINDOW_0_NAME, WINDOW_0_CMD_COUNT, WINDOW_0_CMD_0, etc.
eval "$(python3 -c "
import json, shlex, sys

try:
    with open('$WINDOWS_FILE') as f:
        data = json.load(f)
except (json.JSONDecodeError, FileNotFoundError) as e:
    print(f'echo \"tmux-status-session: error reading {\"$WINDOWS_FILE\"}: {e}\"; exit 1')
    sys.exit(0)

session = data.get('session_name', 'main')
windows = data.get('windows', [])

if not windows:
    print('echo \"tmux-status-session: no windows defined in config\"; exit 1')
    sys.exit(0)

print(f'SESSION={shlex.quote(session)}')
print(f'WINDOW_COUNT={len(windows)}')
for i, w in enumerate(windows):
    print(f'WINDOW_{i}_NAME={shlex.quote(w.get(\"name\", f\"win-{i}\"))}')
    cmds = w.get('commands', [])
    print(f'WINDOW_{i}_CMD_COUNT={len(cmds)}')
    for j, c in enumerate(cmds):
        print(f'WINDOW_{i}_CMD_{j}={shlex.quote(str(c))}')
")"

# ── If session exists, just attach ─────────────────────────────
if tmux has-session -t "$SESSION" 2>/dev/null; then
    exec tmux attach-session -t "$SESSION"
fi

# ── Helper: pin a window name to prevent auto-rename ───────────
pin_window_name() {
    tmux set-window-option -t "$1" automatic-rename off
    tmux set-window-option -t "$1" allow-rename off
}

# ── Create session with first window ───────────────────────────
first_name="WINDOW_0_NAME"
tmux new-session -d -s "$SESSION" -n "${!first_name}"
pin_window_name "${SESSION}:${!first_name}"

# ── Create remaining windows ──────────────────────────────────
for ((i=1; i<WINDOW_COUNT; i++)); do
    name_var="WINDOW_${i}_NAME"
    tmux new-window -t "$SESSION" -n "${!name_var}"
    pin_window_name "${SESSION}:${!name_var}"
done

# ── Schedule commands with staggered delays ────────────────────
# Each window with commands gets a 0.3s incremental delay to avoid
# race conditions between window creation and command execution.
delay_tenths=0
for ((i=0; i<WINDOW_COUNT; i++)); do
    name_var="WINDOW_${i}_NAME"
    cmd_count_var="WINDOW_${i}_CMD_COUNT"
    count="${!cmd_count_var}"
    if [ "$count" -gt 0 ]; then
        delay_tenths=$((delay_tenths + 3))
        # Format delay as seconds with one decimal (e.g., 3 -> 0.3, 6 -> 0.6)
        delay_sec="$((delay_tenths / 10)).$((delay_tenths % 10))"
        for ((j=0; j<count; j++)); do
            cmd_var="WINDOW_${i}_CMD_${j}"
            tmux run-shell -b "sleep ${delay_sec}; tmux send-keys -t '${SESSION}:${!name_var}' '${!cmd_var}' Enter"
        done
    fi
done

# ── Select first window and attach ────────────────────────────
tmux select-window -t "${SESSION}:${!first_name}"
exec tmux attach-session -t "$SESSION"
