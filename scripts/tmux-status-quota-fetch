#!/usr/bin/env python3
"""
tmux-status-quota-fetch — Fetch Claude API usage quota

Fetches Claude usage quota data from the claude.ai API and writes it to the
quota bridge file (configurable via QUOTA_DATA_PATH in settings.conf, default
~/.cache/tmux-status/claude-quota.json). The bridge file is read by
tmux-claude-status to display quota bars in the status bar.

Uses aggressive caching to avoid unnecessary API calls — exits immediately
when the bridge file is still fresh.

Requires: curl_cffi (pip3 install curl-cffi) for TLS fingerprint impersonation.
Cloudflare blocks requests with non-browser TLS fingerprints, so we must
impersonate Chrome's TLS handshake to get through.

Session key setup:
  1. Create ~/.config/tmux-status/claude-usage-key.json:
     {"sessionKey": "sk-ant-...", "expiresAt": "2026-04-13T21:06:09.521Z"}
  2. Or set env var: CLAUDE_USAGE_KEY=sk-ant-...
"""

import json
import os
import sys
import time

HOME = os.path.expanduser("~")
CONFIG_DIR = os.environ.get("XDG_CONFIG_HOME", os.path.join(HOME, ".config"))
SETTINGS_FILE = os.path.join(CONFIG_DIR, "tmux-status", "settings.conf")

def _read_quota_data_path():
    """Read QUOTA_DATA_PATH from settings.conf, default to ~/.cache/tmux-status/claude-quota.json."""
    default = os.path.join(HOME, ".cache", "tmux-status", "claude-quota.json")
    try:
        with open(SETTINGS_FILE) as f:
            for line in f:
                line = line.strip()
                if line.startswith("#") or "=" not in line:
                    continue
                k, v = line.split("=", 1)
                if k.strip() == "QUOTA_DATA_PATH":
                    v = v.strip().strip("'\"")
                    v = os.path.expanduser(v)
                    return v if v else default
    except Exception:
        pass
    return default

BRIDGE_FILE = _read_quota_data_path()
CACHE_DIR = os.path.dirname(BRIDGE_FILE)

DEFAULT_FETCH_INTERVAL = 60
ERROR_FETCH_INTERVAL = 300

REQUEST_HEADERS = {
    "Accept": "*/*",
    "Accept-Language": "en-US,en;q=0.9",
    "Content-Type": "application/json",
    "anthropic-client-platform": "web_claude_ai",
    "anthropic-client-version": "1.0.0",
    "Origin": "https://claude.ai",
    "Referer": "https://claude.ai/settings/usage",
    "Sec-Fetch-Dest": "empty",
    "Sec-Fetch-Mode": "cors",
    "Sec-Fetch-Site": "same-origin",
}


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def write_bridge(data):
    """Write JSON to the bridge file using atomic rename."""
    content = json.dumps(data, indent=2) + "\n"
    os.makedirs(CACHE_DIR, exist_ok=True)
    tmp = BRIDGE_FILE + ".tmp"
    with open(tmp, "w") as f:
        f.write(content)
    os.replace(tmp, BRIDGE_FILE)


def read_bridge():
    """Read and parse the existing bridge file. Returns None on failure."""
    try:
        with open(BRIDGE_FILE) as f:
            return json.load(f)
    except Exception:
        return None


def is_cache_fresh():
    """Check if the bridge file is still within its fetch interval."""
    try:
        stat = os.stat(BRIDGE_FILE)
        bridge = read_bridge()
        if not bridge:
            return False
        interval = bridge.get("fetch_interval", DEFAULT_FETCH_INTERVAL)
        age = time.time() - stat.st_mtime
        return age < interval
    except Exception:
        return False


def read_session_key():
    """
    Read the session key from config file or env var.
    Returns dict with 'sessionKey' and optional 'expiresAt', or None.

    Search order:
      1. ~/.config/tmux-status/claude-usage-key.json
      2. CLAUDE_USAGE_KEY env var
    """
    config_dir = os.environ.get("XDG_CONFIG_HOME", os.path.join(HOME, ".config"))
    key_file = os.path.join(config_dir, "tmux-status", "claude-usage-key.json")

    try:
        raw = open(key_file).read().strip()
        return parse_key_data(raw)
    except Exception:
        pass

    # Env var fallback
    env_val = os.environ.get("CLAUDE_USAGE_KEY", "").strip()
    if env_val:
        return parse_key_data(env_val)

    return None


def parse_key_data(raw):
    """Parse key source — JSON with sessionKey, or bare key string."""
    try:
        obj = json.loads(raw)
        if isinstance(obj, dict) and "sessionKey" in obj:
            return obj
    except (json.JSONDecodeError, TypeError):
        pass
    if raw:
        return {"sessionKey": raw}
    return None


def http_get(url, session_key):
    """
    Perform an HTTPS GET with Chrome TLS fingerprint impersonation.
    Returns (status_code, parsed_json_or_None).
    """
    from curl_cffi import requests as cffi_requests

    headers = {**REQUEST_HEADERS, "Cookie": f"sessionKey={session_key}"}
    r = cffi_requests.get(url, headers=headers, impersonate="chrome131", timeout=15)

    try:
        body = r.json()
    except Exception:
        body = None

    return r.status_code, body


def write_http_error(status_code):
    """Write a bridge file for an HTTP error status code."""
    status_map = {401: "expired", 403: "blocked", 429: "rate_limited"}
    status = status_map.get(status_code, "error")
    bridge = {
        "status": status,
        "timestamp": int(time.time()),
        "fetch_interval": ERROR_FETCH_INTERVAL,
    }
    if status == "error":
        bridge["error"] = f"HTTP {status_code}"
    write_bridge(bridge)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    # 1. Cache check — exit immediately if fresh.
    if is_cache_fresh():
        sys.exit(0)

    # 2. Resolve session key.
    key_data = read_session_key()

    if not key_data:
        write_bridge({
            "status": "no_key",
            "timestamp": int(time.time()),
            "fetch_interval": ERROR_FETCH_INTERVAL,
        })
        sys.exit(0)

    session_key = key_data["sessionKey"]

    # Check expiry if provided.
    expires_at = key_data.get("expiresAt")
    if expires_at:
        try:
            from datetime import datetime, timezone
            exp = datetime.fromisoformat(expires_at.replace("Z", "+00:00"))
            if exp < datetime.now(timezone.utc):
                write_bridge({
                    "status": "key_expired",
                    "expires_at": expires_at,
                    "timestamp": int(time.time()),
                    "fetch_interval": ERROR_FETCH_INTERVAL,
                })
                sys.exit(0)
        except Exception:
            pass

    # 3. Org discovery — prefer cached UUID from existing bridge file.
    org_uuid = None
    existing = read_bridge()
    if existing and existing.get("org_uuid"):
        org_uuid = existing["org_uuid"]

    try:
        if not org_uuid:
            status, orgs = http_get("https://claude.ai/api/organizations", session_key)
            if status != 200:
                write_http_error(status)
                sys.exit(0)
            if not isinstance(orgs, list) or len(orgs) == 0:
                write_bridge({
                    "status": "error",
                    "error": "No organizations found",
                    "timestamp": int(time.time()),
                    "fetch_interval": ERROR_FETCH_INTERVAL,
                })
                sys.exit(0)
            org_uuid = orgs[0]["uuid"]

        # 4. Fetch usage.
        status, usage = http_get(
            f"https://claude.ai/api/organizations/{org_uuid}/usage",
            session_key,
        )
        if status != 200:
            write_http_error(status)
            sys.exit(0)

        # Build bridge output.
        def extract_window(data, name):
            w = data.get(name) or {}
            return {
                "utilization": w.get("utilization"),
                "resets_at": w.get("resets_at"),
            }

        bridge = {
            "status": "ok",
            "org_uuid": org_uuid,
            "five_hour": extract_window(usage, "five_hour"),
            "seven_day": extract_window(usage, "seven_day"),
            "timestamp": int(time.time()),
            "fetch_interval": DEFAULT_FETCH_INTERVAL,
        }

        if expires_at:
            bridge["expires_at"] = expires_at

        write_bridge(bridge)

    except ImportError:
        write_bridge({
            "status": "error",
            "error": "curl_cffi not installed (pip3 install curl-cffi)",
            "timestamp": int(time.time()),
            "fetch_interval": ERROR_FETCH_INTERVAL,
        })
    except Exception as e:
        write_bridge({
            "status": "error",
            "error": str(e),
            "timestamp": int(time.time()),
            "fetch_interval": ERROR_FETCH_INTERVAL,
        })


if __name__ == "__main__":
    main()
